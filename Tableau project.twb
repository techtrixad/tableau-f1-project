      <aliases enabled='yes' />
      <column caption='Actual Finish' datatype='integer' name='[Actual_Finish]' role='measure' type='quantitative' />
      <column caption='Actual Stops' datatype='integer' name='[Actual_Stops]' role='measure' type='quantitative' />
      <column caption='Air Temp C' datatype='real' name='[Air_Temp_C]' role='measure' type='quantitative' />
      <column caption='Avg Speed kmh' datatype='real' name='[Avg_Speed_kmh]' role='measure' type='quantitative' />
      <column caption='Best Finish' datatype='integer' name='[Best_Finish]' role='measure' type='quantitative' />
      <column caption='Avg Race Pace' datatype='real' name='[Calculation_1342002229637123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Lap_Time_s]&lt;100 THEN[Lap_Time_s]END' />
      </column>
      <column caption='Tyre Life Pct' datatype='real' name='[Calculation_1342002229960708]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Laps_On_Tyre]/40)*100' />
      </column>
      <column caption='DOTD Score' datatype='real' name='[Calculation_1342002230177797]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Fan_Vote_pct] * 0.4)&#13;&#10;+ ([Positions_Gained] * 3)&#13;&#10;+ ([Overtakes_Made] * 2)' />
      </column>
      <column caption='Weather Risk' datatype='real' name='[Calculation_1342002230284294]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Rainfall_mm] * 5)&#13;&#10;+ ([Wind_Speed_kmh] * 0.5)' />
      </column>
      <column caption='Consistency Score' datatype='real' name='[Consistency_Score]' role='measure' type='quantitative' />
      <column caption='Dotd Id' datatype='integer' name='[DOTD_ID]' role='dimension' type='ordinal' />
      <column caption='DOTD Winner' datatype='string' name='[DOTD_Winner]' role='dimension' type='nominal' />
