      <aliases enabled='yes' />
      <column caption='Actual Finish' datatype='integer' name='[Actual_Finish]' role='measure' type='quantitative' />
      <column caption='Actual Stops' datatype='integer' name='[Actual_Stops]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Air Temp C (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='0' formula='[Air_Temp_C]' peg='0' size='1.1' />
      </column>
      <column caption='Air Temp C' datatype='real' name='[Air_Temp_C]' role='measure' type='quantitative' />
      <column caption='Avg Speed kmh' datatype='real' name='[Avg_Speed_kmh]' role='measure' type='quantitative' />
      <column caption='Best Finish' datatype='integer' name='[Best_Finish]' role='measure' type='quantitative' />
      <column caption='Gap to Fastest' datatype='real' name='[Calculation_0142710199873536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Race_Pace_s] - { FIXED [Race_Name (Car!Performance)], [Season (Car!Performance)] : MIN([Race_Pace_s]) }' />
      </column>
      <column caption='Performance Tier' datatype='string' name='[Calculation_0142710200041473]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Avg_Speed_kmh] &gt; 217 THEN &quot;High Speed&quot; ELSEIF [Avg_Speed_kmh] &gt; 212 THEN &quot;Balanced&quot; ELSE &quot;Technical&quot; END' />
      </column>
      <column caption='Avg race pace' datatype='real' name='[Calculation_0142710204502018]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Race_Pace_s])' />
      </column>
      <column caption='Max top speed' datatype='real' name='[Calculation_0142710204772355]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Top_Speed_kmh])' />
      </column>
      <column caption='Blank' datatype='string' name='[Calculation_0142710205575172]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot; &quot;' />
      </column>
      <column caption='Best sector' datatype='real' name='[Calculation_0142710209093637]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Sector1_Advantage_s])' />
      </column>
      <column caption='Best Stop' datatype='real' name='[Calculation_0142710219341831]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Pit_Duration_s])' />
      </column>
      <column caption='Track Conditionions' datatype='string' name='[Calculation_0142710281068553]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Track_Temp_C] &gt;= 40 THEN &quot;Extreme Heat&quot;&#13;&#10;ELSEIF [Track_Temp_C] &gt;= 30 THEN &quot;Optimal&quot;&#13;&#10;ELSEIF [Track_Temp_C] &lt; 20 THEN &quot;Cold (Tire Warm-up Issue)&quot;&#13;&#10;ELSE &quot;Standard&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Race Pace' datatype='real' name='[Calculation_1342002229637123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Lap_Time_s]&lt;100 THEN[Lap_Time_s]END' />
      </column>
      <column caption='Tyre Life Pct' datatype='real' name='[Calculation_1342002229960708]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Laps_On_Tyre]/40)*100' />
      </column>
      <column caption='DOTD Score' datatype='real' name='[Calculation_1342002230177797]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Fan_Vote_pct] * 0.4)&#13;&#10;+ ([Positions_Gained] * 3)&#13;&#10;+ ([Overtakes_Made] * 2)' />
      </column>
      <column caption='Weather Risk' datatype='real' name='[Calculation_1342002230284294]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Rainfall_mm] * 5)&#13;&#10;+ ([Wind_Speed_kmh] * 0.5)' />
      </column>
      <column caption='Consistency Score' datatype='real' name='[Consistency_Score]' role='measure' type='quantitative' />
