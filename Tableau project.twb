    <worksheet name='Weather Impact analysis'>
      <table>
        <view>
          <datasources>
            <datasource caption='Race_Results+ (F1_Race_Intelligence_Dataset)' name='federated.0yln6ov0axmm961cdlp4c0va91eo' />
          </datasources>
          <datasource-dependencies datasource='federated.0yln6ov0axmm961cdlp4c0va91eo'>
            <column caption='Track Conditionions' datatype='string' name='[Calculation_0142710281068553]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Track_Temp_C] &gt;= 40 THEN &quot;Extreme Heat&quot;&#13;&#10;ELSEIF [Track_Temp_C] &gt;= 30 THEN &quot;Optimal&quot;&#13;&#10;ELSEIF [Track_Temp_C] &lt; 20 THEN &quot;Cold (Tire Warm-up Issue)&quot;&#13;&#10;ELSE &quot;Standard&quot;&#13;&#10;END' />
            </column>
            <column caption='Weather Risk' datatype='real' name='[Calculation_1342002230284294]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Rainfall_mm] * 5)&#13;&#10;+ ([Wind_Speed_kmh] * 0.5)' />
            </column>
            <column datatype='string' name='[Circuit (Weather!Impact)]' role='dimension' type='nominal' />
            <column caption='Race Name (Weather!Impact)' datatype='string' name='[Race_Name (Weather!Impact)]' role='dimension' type='nominal' />
            <column caption='Rainfall mm' datatype='real' name='[Rainfall_mm]' role='measure' type='quantitative' />
            <column aggregation='Sum' datatype='integer' name='[Season (Weather!Impact)]' role='dimension' type='ordinal' />
            <column caption='Track Temp C' datatype='real' name='[Track_Temp_C]' role='measure' type='quantitative' />
            <column caption='Wind Speed kmh' datatype='real' name='[Wind_Speed_kmh]' role='measure' type='quantitative' />
